# MiniOpenClaw 配置文件
# 复制此文件为 .env 并填入你的 API Key:
#   cp .env.example .env
#
# .env 文件不会被提交到 git（已在 .gitignore 中忽略）。

# DeepSeek API Key（必填，使用真后端时）
DEEPSEEK_API_KEY=sk-your-api-key-here

# DeepSeek API 地址（可选，默认值如下）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称（可选，默认值如下）
DEEPSEEK_MODEL=deepseek-chat

# 模型上下文窗口（单位：token）。设置后会影响触发上下文压缩的阈值。
# 留空则根据 DEEPSEEK_MODEL 自动映射（如 deepseek-v4-flash → 1_000_000）。
DEEPSEEK_CONTEXT_WINDOW=

# 直接指定触发上下文压缩的 token 预算（优先级高于 DEEPSEEK_CONTEXT_WINDOW）。
# MINIOPENCLAW_TOKEN_BUDGET=900000

# 工具输出超过多少字符时自动写入文件（默认 8000）。
# MINIOPENCLAW_SPILL_THRESHOLD=8000

# 长工具输出写入的目录（默认 .mini-openclaw/spill，相对于工作区）。
# MINIOPENCLAW_SPILL_DIR=.mini-openclaw/spill

# web_fetch 出站策略：
# public（默认）允许正常公网 HTTP/HTTPS，仍拦截内网、危险域名并要求工具确认。
# allowlist 仅允许默认白名单及 MINIOPENCLAW_WEB_ALLOW_HOSTS 追加的域名。
MINIOPENCLAW_WEB_POLICY=public
MINIOPENCLAW_WEB_ALLOW_HOSTS=

# 逗号分隔的额外禁止域名（内置演示域名 evil.com 始终禁止）
MINIOPENCLAW_WEB_BLOCK_HOSTS=
